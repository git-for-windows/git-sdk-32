prefix=/mingw32
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/lib

Name: GNU MPC
Description: A complex floating-point library with exact rounding
URL: https://www.multiprecision.org/mpc/
Version: 1.4.1
Requires.private: mpfr >= 4.1.0, gmp >= 5.0.0
Cflags: -I${includedir}
Libs: -L${libdir} -lmpc
